    "scripts": {
        "build": "pnpm run webapp:prod --",
        "clean-www": "rimraf build/resources/main/static/app/{src,build/}",
        "compile": "pnpm run prebuild && tsc --project tsconfig.app.json",
        "compile:tests": "pnpm run prebuild && tsc --project tsconfig.spec.json",
        "coverage:check-module": "node supporting_scripts/code-coverage/module-coverage-client/check-client-module-coverage.mjs",
        "coverage:pr": "node supporting_scripts/code-coverage/local-pr-coverage/local-pr-coverage.mjs",
        "lint": "eslint src/main/webapp",
        "lint:fix": "eslint --fix src/main/webapp",
        "lint:docs": "pnpm -C documentation run lint",
        "lint:playwright": "pnpm -C src/test/playwright run lint",
        "postinstall": "husky && node src/main/webapp/app/lecture/manage/pdf-preview/pdfjs_copy_worker_script.mjs",
        "prebuild": "node prebuild.mjs",
        "prepare": "husky",
        "prettier:check": "prettier --check \"src/{main/webapp,test}/**/*.{json,ts,js,css,scss,html}\"",
        "prettier:write": "prettier --write \"src/{main/webapp,test}/**/*.{json,ts,js,css,scss,html}\"",
        "start": "pnpm run prebuild -- --develop && ng serve --hmr",
        "test-diff:ci": "git fetch origin develop && pnpm run prebuild && pnpm run vitest:diff && ng test --log-heap-usage -w=4 --ci --reporters=default --reporters=jest-junit --pass-with-no-tests --changed-since=origin/develop",
        "test-diff": "pnpm run prebuild && pnpm run vitest:diff && ng test --log-heap-usage -w=4 --pass-with-no-tests --changed-since=origin/develop --coverage",
        "test:ci": "pnpm run prebuild && pnpm run vitest:ci && pnpm run jest:ci",
        "test:leaks": "pnpm run prebuild && ng test --log-heap-usage --detect-leaks",
        "test:open-handles": "pnpm run prebuild && ng test --detect-open-handles",
        "test": "pnpm run prebuild && ng test --coverage --log-heap-usage -w=4",
        "testw8": "pnpm run prebuild && ng test --coverage --log-heap-usage -w=8",
        "test:one": "pnpm run prebuild && ng test",
        "jest:ci": "cross-env NODE_OPTIONS='--max-old-space-size=8192 --max-semi-space-size=128' ng test --coverage --log-heap-usage -w=4 --ci --reporters=default --reporters=jest-junit",
        "setupCourse": "node supporting_scripts/course-scripts/setup-course/setup-course.mjs",
        "vitest": "vitest",
        "vitest:run": "vitest run",
        "vitest:ci": "cross-env NODE_OPTIONS='--max-old-space-size=8192 --max-semi-space-size=128' pnpm exec vitest run --coverage --maxWorkers=2",
        "vitest:coverage": "vitest run --coverage",
        "vitest:diff": "vitest run --changed origin/develop --passWithNoTests",
        "vitest:ui": "vitest --ui",
        "sync-versions": "node supporting_scripts/sync-client-versions.mjs",
        "sync-versions:check": "node supporting_scripts/sync-client-versions.mjs --check",
        "sync-versions:reverse": "node supporting_scripts/sync-client-versions.mjs --reverse",
        "update": "ncu -i --format group",
        "webapp:build": "pnpm run clean-www && pnpm run prebuild -- --develop && ng build --configuration development",
        "webapp:prod": "pnpm run clean-www && pnpm run prebuild && cross-env NG_BUILD_OPTIMIZE_CHUNKS=1 ng build --configuration production",
        "sbom:generate-full": "cross-env FETCH_LICENSE=false pnpm dlx @cyclonedx/cdxgen@12.4.0 --type pnpm --output build/reports/client-sbom-full.json --spec-version 1.6 --no-babel --no-recurse --profile generic",
        "sbom:filter-shipped": "node supporting_scripts/sbom-filter-by-bundle.mjs build/reports/client-sbom-full.json build/reports/client-sbom.json build/resources/main/static",
        "sbom:generate": "pnpm run sbom:generate-full && pnpm run sbom:filter-shipped"
    }
}
