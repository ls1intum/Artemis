# Project-wide workaround for the webapp build which might fail due to JavaScript heap memory leaks.
node-options=--max-old-space-size=6144

# Compatibility layer: keep an npm-like hoisted node_modules so legacy tooling
# (Angular asset paths in angular.json, Jest moduleNameMapper, the pdfjs
# postinstall copy script, gradle-node-plugin) continues to resolve packages at
# the top level. Tighten by setting shamefully-hoist=false in a follow-up once
# phantom dependencies are surfaced and made explicit.
shamefully-hoist=true
public-hoist-pattern[]=*

# Treat the lockfile as authoritative; never silently update it during install.
prefer-frozen-lockfile=true

# Allow our own pre/post lifecycle scripts (postinstall, prepare) to run.
enable-pre-post-scripts=true
