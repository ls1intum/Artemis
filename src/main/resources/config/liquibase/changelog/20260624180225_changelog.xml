<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260624180225-1-mysql" author="matyasht" dbms="mysql,h2">
        <addColumn tableName="exam">
            <column name="exam_mode" type="ENUM('REAL','TEST','TEST_WITH_SIMULATION')" defaultValue="REAL">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="20260624180225-1-postgres" author="matyasht" dbms="postgresql">
        <addColumn tableName="exam">
            <column name="exam_mode" type="text" defaultValue="REAL">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="20260624180225-2" author="matyasht">
        <update tableName="exam">
            <column name="exam_mode" value="TEST"/>
            <where>test_exam = TRUE</where>
        </update>
    </changeSet>

    <changeSet id="20260624180225-3" author="matyasht">
        <dropColumn tableName="exam" columnName="test_exam"/>
    </changeSet>
</databaseChangeLog>
