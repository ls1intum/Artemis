<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260614120000-1-add-origin-mysql" author="liam-berger" dbms="mysql,h2">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="iris_message" columnName="origin"/></not>
        </preConditions>
        <addColumn tableName="iris_message">
            <column name="origin" type="ENUM('PROACTIVE_STRUGGLE')"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260614120000-1-add-origin-postgres" author="liam-berger" dbms="postgresql">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="iris_message" columnName="origin"/></not>
        </preConditions>
        <addColumn tableName="iris_message">
            <column name="origin" type="text"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
