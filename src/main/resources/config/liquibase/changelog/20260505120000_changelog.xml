<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260505-01-add-slide-page-numbers-column" author="pyris-integration">
        <comment>Add slide_page_numbers column to attachment for PDF page number tracking (stored as TEXT, JSON serialization handled by JPA converter)</comment>
        <addColumn tableName="attachment">
            <column name="slide_page_numbers" type="TEXT">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
